# Copy to .env and fill once competition keys are available (challenge opens 2026-07-06).
# Defaults below keep everything offline (mock providers + local memory) so it runs today.
# After filling, validate everything with:  python scripts/live_check.py

RESONATE_MODE=mock                 # mock | live
RESONATE_TRANSLATION=NIV           # live default (accept Biblica's license on YouVersion first);
                                   # offline mock samples remain public-domain KJV
RESONATE_BIBLE_ID=                 # numeric YouVersion bible id — scripts/live_check.py resolves it

RESONATE_MEMORY=local              # local | redis
REDIS_URL=                         # e.g. redis://default:password@host:port  (Redis Cloud / Upstash)

# --- Gloo AI Studio (studio.ai.gloo.com -> Dashboard -> API Credentials) ---
# OAuth2 client-credentials: the engine exchanges these for a 1h access token automatically.
GLOO_CLIENT_ID=
GLOO_CLIENT_SECRET=
GLOO_BASE_URL=https://platform.ai.gloo.com
GLOO_MODEL=                        # empty = auto_routing (recommended); or e.g. gloo-anthropic-claude-haiku-4.5
GLOO_TRADITION=                    # optional theological lens, e.g. evangelical

# --- YouVersion Platform (platform.youversion.com -> your app -> app key) ---
# IMPORTANT: also ACCEPT the license agreement for each Bible you'll fetch (e.g. KJV)
# under Licensing on platform.youversion.com, or passage calls will fail.
YOUVERSION_APP_KEY=
YOUVERSION_BASE_URL=https://api.youversion.com/v1
