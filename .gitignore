# secrets
.env

# python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# node / web (later phases)
node_modules/
.next/
# build output is NEVER tracked — Render builds it (render.yaml buildCommand), and a
# tracked dist can be silently reverted to a stale bundle by sync tools (observed
# 2026-07-12: OneDrive restored the committed dist over two fresh local builds)
dist/

# build artifacts / scratch
out/
*.log
.DS_Store

# persisted runtime memory (per-user recurring themes)
.memory.json
data/.memory.json
*.memory.json*

# guardian registrations — PERSONAL CONTACT DATA, never commit (see data/guardians.example.json)
data/guardians.json
data/guardians.json.log

# cached YouVersion verse text (derived; re-warms itself on boot)
data/.yv-cache.json
data/.yv-cache.json.tmp

# generated audio (voice cache + tuning lab renders)
data/.tts-cache/
data/voice-lab/

# generated training corpora (the live one ships as a Kaggle dataset, not in-repo)
data/corpus/
